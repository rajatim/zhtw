{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rajatim/zhtw/benchmarks/accuracy/competitors-lock.schema.json",
  "title": "zhtw benchmark competitor environment lock",
  "type": "object",
  "required": [
    "version",
    "generated_date",
    "status",
    "policy",
    "environment",
    "formal_engine_ids",
    "ranking_families",
    "competitors"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 2 },
    "generated_date": { "type": "string", "format": "date" },
    "status": { "type": "string", "const": "locked" },
    "policy": { "type": "string", "minLength": 1 },
    "environment": {
      "type": "object",
      "required": [
        "image_repository",
        "environment_sha256",
        "dockerfile",
        "build_command",
        "run_command",
        "protocol",
        "timeout_seconds",
        "base_images",
        "files"
      ],
      "additionalProperties": false,
      "properties": {
        "image_repository": { "type": "string", "minLength": 1 },
        "environment_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "dockerfile": { "type": "string", "pattern": "^benchmarks/accuracy/competitor-env/Dockerfile$" },
        "build_command": { "type": "string", "minLength": 1 },
        "run_command": { "type": "string", "minLength": 1 },
        "protocol": { "type": "string", "const": "jsonl-v1" },
        "timeout_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 60 },
        "base_images": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["reference", "index_digest", "platform_digests"],
            "additionalProperties": false,
            "properties": {
              "reference": { "type": "string", "minLength": 1 },
              "index_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
              "platform_digests": {
                "type": "object",
                "required": ["linux/amd64", "linux/arm64"],
                "additionalProperties": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
              }
            }
          }
        },
        "files": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "formal_engine_ids": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
    },
    "ranking_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "engine_ids", "ranking_representative"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "engine_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string" }
          },
          "ranking_representative": { "type": "string", "minLength": 1 }
        }
      }
    },
    "competitors": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "included_in_formal_runner",
          "adapter",
          "family",
          "package",
          "version",
          "license",
          "artifact_sha256",
          "source_url",
          "command",
          "locale_or_config",
          "config_sha256",
          "version_probe",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "display_name": { "type": "string", "minLength": 1 },
          "included_in_formal_runner": { "type": "boolean" },
          "adapter": { "type": "string", "enum": ["local_python", "container_jsonl"] },
          "family": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "package": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "license": { "type": "string", "minLength": 1 },
          "artifact_sha256": {
            "type": "object",
            "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          },
          "source_url": { "type": "string", "format": "uri" },
          "command": { "type": "string", "minLength": 1 },
          "locale_or_config": { "type": "string", "minLength": 1 },
          "config_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "version_probe": { "type": "string", "minLength": 1 },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
