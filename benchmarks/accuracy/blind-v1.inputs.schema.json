{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rajatim/zhtw/benchmarks/accuracy/blind-v1.inputs.schema.json",
  "title": "zhtw sealed holdout input dataset",
  "type": "object",
  "required": [
    "version",
    "name",
    "dataset",
    "description",
    "generated_date",
    "status",
    "publish_state",
    "target_total",
    "source_policy",
    "annotation_protocol",
    "batches",
    "stats",
    "cases"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "const": "blind-v1.inputs" },
    "dataset": { "type": "string", "const": "blind-v1" },
    "description": { "type": "string", "minLength": 1 },
    "generated_date": { "type": "string", "format": "date" },
    "status": {
      "type": "string",
      "enum": ["collecting_inputs", "frozen_inputs", "released"]
    },
    "publish_state": {
      "type": "string",
      "enum": ["public_inputs_only", "public_full_benchmark"]
    },
    "target_total": { "type": "integer", "const": 2000 },
    "source_policy": {
      "type": "object",
      "required": [
        "expected_not_in_inputs",
        "allowed_input_sources",
        "forbidden_expected_sources",
        "copyright_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "expected_not_in_inputs": { "type": "boolean", "const": true },
        "allowed_input_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_expected_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "copyright_policy": { "type": "string", "minLength": 1 }
      }
    },
    "annotation_protocol": {
      "type": "object",
      "required": [
        "review_order",
        "minimum_human_reviewers",
        "adjudication_required_on_disagreement",
        "normalization"
      ],
      "additionalProperties": false,
      "properties": {
        "review_order": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "minimum_human_reviewers": { "type": "integer", "minimum": 2 },
        "adjudication_required_on_disagreement": { "type": "boolean", "const": true },
        "normalization": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "domain", "target_cases", "priority", "focus"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "target_cases": { "type": "integer", "minimum": 1 },
          "priority": { "type": "integer", "minimum": 1 },
          "focus": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "stats": {
      "type": "object",
      "required": ["total_collected", "by_domain", "by_risk"],
      "additionalProperties": false,
      "properties": {
        "total_collected": { "type": "integer", "minimum": 0 },
        "by_domain": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_risk": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "batch",
          "domain",
          "input",
          "risk",
          "source",
          "tags",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "batch": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "input": { "type": "string", "minLength": 1 },
          "risk": {
            "type": "string",
            "enum": ["baseline_guard", "over_conversion_guard", "candidate_gap"]
          },
          "source": {
            "type": "object",
            "required": ["type", "citation", "license"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "citation": { "type": "string", "minLength": 1 },
              "license": { "type": "string", "minLength": 1 }
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
