tent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_F_1-4_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_F_1-6_ori","input":"我们一进游乐园的大门，就开始下雨了。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_F_1-6_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_F_2-12_ori","input":"天哪！","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_F_2-12_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_G_1-3_ori","input":"第二天早上7点半我起床了起了很快，8点我上车到朋友的学校，到大学以后，她和其他的女士门，我们互相认识，然后请我们吃好吃的清真的饭，过了一会儿我门去上车开始第一次爬山的旅行开始了。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_G_1-3_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_H_1-19_ori","input":"可是我们不能回去了！","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_H_1-19_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_H_1-27_ori","input":"我很想再见他们。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_H_1-27_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_H_1-2_ori","input":"所以我希望了长大以后我要去菲律宾旅行。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_H_1-2_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_H_2-10_ori","input":"还走访了凤凰古镇，感受明清时代建在北方的南方小镇，那里真的特别美，好像自己回到了古代的中国一样，真的好想再去一次；","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_H_2-10_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_H_2-2_ori","input":"因为在陕西电视台里有一个带着外国人一起旅行的节目，他们邀请了我，所以我们一起去了商洛。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_H_2-2_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_H_2-9_ori","input":"之后我们去了商洛很小的城市，看到这城市很有特色，我们游览了天然奇观喀斯特地貌柞水溶洞，溶洞里面都是冬暖夏凉，大自然真的好神奇；","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_H_2-9_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_I_1-1_ori","input":"我要开始讲对我的初恋。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_I_1-1_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_I_1-3_ori","input":"去年我跟朋友们一起玩的时候，一个我的韩国朋友给我介绍了一个中国男孩儿。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_I_1-3_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_J_1-6_ori","input":"我被着惊人的举动惊呆了，一个残疾人都可以做到的事，为什么我们做不到？","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_J_1-6_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_L_1-13_ori","input":"那时，我决定公开求婚在山顶上。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_L_1-13_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_L_1-14_ori","input":"恰巧长白山山顶的名字也是天池。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_L_1-14_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_L_1-4_ori","input":"当然我一个人去的。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_L_1-4_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_L_1-6_ori","input":"在兰州我给她打个电话，突然她说告别。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_L_1-6_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_M_1-28_ori","input":"在毕业晚会的时候，我看到她男朋友手握玫瑰向她求婚，她穿着很漂亮的礼服。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_M_1-28_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_O_1-18_ori","input":"这一次旅行之所以难忘，其中一个原因就是我帮助我的两个好朋友在一起，并且他们现在已经成为夫妇了。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_O_1-18_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_P_1-5_ori","input":"我觉得这可能是因为中国上班比较早，所以一般中国人没有吃早饭的时间。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_P_1-5_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_X_1-2_ori","input":"胜利是属于最前面那个黑人！","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_X_1-2_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_X_1-3_ori","input":"得了冠军的他张开双臂欢呼，我觉得他一定不敢相信自己眼前的这一切。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_X_1-3_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_Y_1-4_ori","input":"学校的早晨是有声有色的，一到学校门口两旁树上的小鸟便会叽叽喳喳地叫，好像在说：“老师，同学们，早上好！”","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_Y_1-4_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_Y_1-6_ori","input":"因为快要上课了，他们害怕迟到，所以他们一边吃着早饭，一边跑去教室。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_Y_1-6_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_Z_1-14_ori","input":"但是上下班的时候因交通混乱而堵车很厉害，只是过这一站就要30分钟的时间，太麻烦了，还是骑自行车快。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_Z_1-14_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_Z_1-15_ori","input":"所以很多北京人这样为避免道路上的时间浪费和麻烦选择骑自行车。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_Z_1-15_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ud-chinese-cfl-v1/CFL_Z_1-9_ori","input":"自行车就能把我们学生的生活变得很轻松。","provenance":{"raw_url":"https://raw.githubusercontent.com/UniversalDependencies/UD_Chinese-CFL/ad71b068e4581343dab897ef2d54abf102580897/zh_cfl-ud-test.conllu","source_case_id":"CFL_Z_1-9_ori","split":"test"},"source_id":"ud-chinese-cfl-v1"}],"converter_output_used":false,"dataset":"blind-v2","generated_date":"2026-07-20","input_only":true,"name":"blind-v2-source-classification-batch-001","seed":20260719,"selection_polic