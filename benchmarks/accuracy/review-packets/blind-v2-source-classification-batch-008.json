{"batch_number":8,"batch_size":32,"cases":[{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-001","input":"欢迎来到阿卡迪亚国家公园，它是北大西洋海岸线上的皇冠瑰宝。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-001","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-002","input":"请在 nps.gov/acadia 上了解有关公园的更多信息并制定游览计划。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-002","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-003","input":"所有 16 岁及以上的游客都必须持有公园通行证。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-003","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-004","input":"所有车辆必须出示通过挡风玻璃清晰可见的通行证。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-004","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-005","input":"go.nps.gov/ AcadiaPass 在线全面介绍了通行证购买选项。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-005","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-006","input":"如果您想在5月下旬至10月中旬之间开车沿凯迪拉克山峰路行驶，您还需要预订车辆。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-006","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-007","input":"预定只能提前在线出售，不能在公园内亲自购买。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-007","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-008","input":"在公园露营地露营需要提前在 Recreation.gov 上预订。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-008","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-009","input":"阿卡迪亚的任何地方都不允许野外露营或过夜停车。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-009","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-010","input":"附近的城镇可以提供住宿。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-010","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-011","input":"除凯迪拉克山以外的公园大部分地区和周边社区，都可提供免票的 Island Explorer 服务。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-011","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-012","input":"使用丙烷动力巴士可以减少交通拥堵和空气污染。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-012","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-013","input":"阿卡迪亚公园欢迎宠物，但必须遵守相关规定。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-013","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-014","input":"联邦法律要求所有宠物必须被拴在不超过6英尺(2米)的皮带上。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-014","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-015","input":"请收集动物粪便并丢弃在垃圾容器中。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-015","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-016","input":"所有自然区域都会构成风险。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-016","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-017","input":"您的安全取决于您自己的正确判断。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-017","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-018","input":"在出发前往公园的徒步道之前，请仔细研究计划路线上的危险和挑战。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-018","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-019","input":"请不要将手机当作地图或手电筒。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-019","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-020","input":"在条件允许的情况下，始终携带额外的水、详细的地图、保暖衣物和脚部牵引器。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-020","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-021","input":"自行车和马匹不允许在徒步道上骑行。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-021","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-022","input":"马车道全年开放，可供多种娱乐使用。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-022","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-023","input":"行人必须为马让路，骑自行车的人必须为马和行人让路。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-023","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-024","input":"只有1类电动自行车才允许在马车道上行驶。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-024","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-025","input":"禁止使用机动车辆和2类、3类电动自行车。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-025","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-026","input":"冬季，请避免践踏平整过的雪道。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-026","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-027","input":"请让阿卡迪亚保持原有的样子。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-027","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-028","input":"您只能在指定的步道和耐用的地面上行走。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-028","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-029","input":"请收拾垃圾和宠物垃圾。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-029","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-030","input":"确保食物安全，与野生动物保持距离。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-030","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-031","input":"请勿堆放岩石或改变用于步道导航的石标。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-031","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"nps-essential-acadia-simplified-v1/sentence-032","input":"如果您发现文物，请将它放在原处，拍张照片，记下位置，然后告诉公园护林员。","provenance":{"raw_url":"https://www.nps.gov/articles/000/essential-acadia_simplified-chinese.htm","source_case_id":"sentence-032","split":"article"},"source_id":"nps-essential-acadia-simplified-v1"}],"converter_output_used":false,"dataset":"blind-v2","generated_date":"2026-07-23","input_only":true,"name":"blind-v2-source-classification-batch-008","seed":20260719,"selection_policy":"all-source-cases-sorted-v1","source_snapshots":[{"id":"nps-essential-acadia-simplified-v1","path":"benchmarks/accuracy/external/nps-essential-acadia-simplified-v1.json","sha256":"f654d0a39a3ca2ea74403d097b448ddebe12bbb9da8394042d06382b0436d344"}],"stats":{"by_source":{"nps-essential-acadia-simplified-v1":32},"total":32},"status":"needs_codex_first_pass","version":1}
