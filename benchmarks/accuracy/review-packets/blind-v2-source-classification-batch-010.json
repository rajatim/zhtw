{"batch_number":10,"batch_size":100,"cases":[{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-001","input":"操作链锯存在危险，使用适当的个人防护装备和遵守安全操作程序可以最大限度地减少潜在的伤害。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-001","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-003","input":"确保链条始终锋利且油箱已加满。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-003","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-004","input":"在地面或其他稳固的支撑物上启动锯；严禁悬空启动。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-004","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-005","input":"在距离加油区至少 10 英尺（3米）的地方启动，并开启链锯制动器。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-005","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-006","input":"使用经认可的容器给链锯加油。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-006","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-007","input":"进行加油操作时，需要在距离所有火源至少 10 英尺（3米）的地方进行；加油时禁止吸烟。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-007","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-008","input":"将燃料倒入链锯中时使用漏斗或软管。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-010","input":"清除链锯导板上的污垢、碎片、小树枝和石块。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-010","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-011","input":"砍伐树木之前，请检查树上是否有钉子、尖刺或其他金属。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-011","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-013","input":"用双手握持锯柄，并在操作链锯时保持平衡。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-013","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-014","input":"操作链锯时必须佩戴适当的个人防护装备，包括手、脚、腿、眼睛、面部、听力和头部的保护装置。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-014","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-015","input":"不要穿宽松的衣服。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-015","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-017","input":"留意受压的树枝，切割时它们可能会崩出。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-017","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-018","input":"汽油链锯必须配备保护装置，以最大限度地减少链锯反冲。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-018","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-chainsaw-safety-simplified-v1/sentence-019","input":"为避免反冲，请勿使用端头进行切割。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4286.pdf","source_case_id":"sentence-019","split":"document"},"source_id":"osha-chainsaw-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-005","input":"如果您是参与清理和重建活动的雇主、工人、房主或市民，请务必在参与这些活动之前评估危险性和（或）遇到危险的可能性。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-005","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-008","input":"被洪水淹没的工业和废弃矿场的有毒物质。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-009","input":"空气中的霉菌和真菌。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-009","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-010","input":"对封闭空间用新鲜空气进行通风。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-010","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-024","input":"树木的修剪与杂物清除与倒下的电力线相连接的电线或树枝有带电的危险，与之接触会导致触电。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-024","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-026","input":"链锯和切割机等设备造成的伤害。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-026","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-030","input":"做出清晰的标记，以标示出树木残片可能落到工人身上的危险区域。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-030","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-036","input":"如果不可行，请使用更多的工人和适当的举升方式。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-036","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-041","input":"遵从适当的用梯安全（如：梯子架设在坚固稳定的地方，上下梯时保持“三点”接触，不要站在最上面的梯级上）。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-041","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-043","input":"便携发电机燃气或柴油发电机导致的电击和触电。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-043","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-047","input":"检查电线以确保它们状况良好且没有破损；使用接地故障断路器 (GFCI)。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-047","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-048","input":"确保发电机运行的地方通风良好。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-048","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-062","input":"相关的详细信息请参阅29 CFR 1910.146。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-062","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-070","input":"OSHA还向工人和雇主提供信息、进行培训和协助。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-070","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-cleanup-simplified-v1/sentence-075","input":"这些信息将根据要求提供给有视听障碍的人。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA_FS-4355.pdf","source_case_id":"sentence-075","split":"document"},"source_id":"osha-disaster-cleanup-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-001","input":"应急救援人员在应对自然和人为灾难时，会面临因滑倒、绊倒和跌倒而受伤甚至死亡的风险。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-001","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-002","input":"雇主必须采取的、确保工人安全的步骤包括：制定事前灾难响应方案并确保应急救援人员了解该方案。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-002","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-003","input":"评估作业场地，以确定其是否存在或可能存在危险。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-003","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-004","input":"提供防护装备以防止滑倒、绊倒和跌倒，它们包括：防滑鞋（例如橡胶鞋底）。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-004","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-005","input":"手套，工人可以牢固地抓住栏杆 / 梯子以稳定自己。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-005","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-006","input":"头部防护装置个人跌落保护培训员工们识别危险——包括需要防护装备的危险，以及如何防止受伤。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-006","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-007","input":"尽量避免在湿滑的地方行走；将湿掉的鞋底擦干。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-007","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-008","input":"使用手电筒或头盔灯，以避开洞口或地板开口、潮湿或光滑的表面、以及碎片或设备。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-009","input":"在目视检查以确保没有孔洞或薄弱处、并且可以支撑工人及其设备的重量之前，请勿踏上任何表面。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-009","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-010","input":"攀爬梯子时切勿手持设备或工具。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-010","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-011","input":"使用背包和工具带以固定设备、解放双手。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-011","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-012","input":"在高空未受保护的边缘附近移动或执行应急救援时，使用防坠落保护装置。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-012","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-013","input":"将滑倒、绊倒和跌倒的危险用通讯设备——尤其是免提设备——通知雇主/救援主管和其他工人。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-013","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-disaster-falls-simplified-v1/sentence-014","input":"当您对某项任务的安全性有疑问时，请停止并通知主管。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4301.pdf","source_case_id":"sentence-014","split":"document"},"source_id":"osha-disaster-falls-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-001","input":"电会导致灼伤、电击甚至触电（死亡）等危险。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-001","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-002","input":"所有架空电线都可能已通电且为致命电压。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-002","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-003","input":"永远不要认为电线是安全的，即使它是垂下的或看起来是绝缘的。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-003","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-004","input":"切勿接触掉落的架空电线，通知电力公司该掉落的电线。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-004","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-005","input":"在清理和其他活动期间，与架空电线保持至少 10英尺（3米）的距离。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-005","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-006","input":"如果您在高处工作或处理长物体，请在工作开始前核实该区域是否存在架空电线。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-006","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-007","input":"如果在您驾车时，架空电线掉落至您的车辆上，请留在车内并继续驶离电线；如果发动机熄火，请勿离开车辆。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-007","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-008","input":"警告其他人不要触摸该车辆或电线。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-009","input":"致电或请人致电当地电力公司和紧急服务中心。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-009","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-010","input":"站在水中时切勿操作电气设备。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-010","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-011","input":"除非有相关资质和授权，切勿修理插线板或电气设备。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-011","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-012","input":"在通电前，让有资质的电工检查曾经受潮的电气设备。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-012","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-013","input":"如果在潮湿的地方工作，检查电线和设备以确保它们状况良好且没有缺陷，并使用接地故障断路器(GFCI)。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-013","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-electrical-safety-simplified-v1/sentence-014","input":"在靠近通电的地方工作时，一定要谨慎小心。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4281.pdf","source_case_id":"sentence-014","split":"document"},"source_id":"osha-electrical-safety-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-002","input":"我在 2009 年的一次职业事故中失去了一位亲人，因此我了解并理解你们所遭受的直接打击。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-002","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-004","input":"我希望通过帮助您解决有关您亲人的事故、检查过程、工人纪念日和/或 OSHA 的任何问题，来减轻您的一些担忧。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-004","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-007","input":"哀伤的常见阶段：否认、愤怒、纠结、抑郁、接受照顾好自己。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-007","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-008","input":"分享/创建纪念物品或活动。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-011","input":"OSHA 设立了一个虚拟的工人纪念墙，以纪念在工作中失去生命的同事。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-011","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-013","input":"其他 7 个州计划（康涅狄格州、伊利诺伊州、缅因州、马萨诸塞州、新泽西州、纽约州和维尔京群岛）仅涵盖州和地方政府工作人员。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-013","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-014","input":"须知和期望 OSHA 将对您亲人的事故进行调查，以确定是否违反了 OSHA 规定。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-014","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-015","input":"我们在六个月内完成调查，希望你理解。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-015","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-016","input":"所有罚金将直接上缴美国财政部；它们不会被当做OSHA 预算或收入。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-016","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-017","input":"OSHA 不会仅仅因为工作场所发生死亡事故就发出违规通知。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-017","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-020","input":"检查结束后，地区主管将回答你的问题并解释处理方案。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-020","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-021","input":"OSHA 将在结案时通知你。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-021","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-022","input":"《信息自由法案》（FOIA）规定了 OSHA 事故检查信息的发布。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-022","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-fallen-workers-family-simplified-v1/sentence-023","input":"在案件结案后，根据书面申请， OSHA 将向您提供根据《信息自由法》可以公开的部分检查档案，您作为家庭成员无需支付任何费用。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/FALLEN-WORKERS-BROCHURE-2023-ZH-SI.pdf","source_case_id":"sentence-023","split":"document"},"source_id":"osha-fallen-workers-family-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-002","input":"工地的有效安全与健康项目会让您的工人更好地，更有效率地工作，提高生产率，并确保产品质量。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-002","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-004","input":"参加OSHA现场咨询项目是一种回馈工人的方式。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-004","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-005","input":"工人安全是经营一个成功企业的必要条件。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-005","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-007","input":"小型企业可能没有预算来雇佣一个安全专家，但是这个项目可以免费提供相似的建议。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-007","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-008","input":"即使您的企业还没有经历任何与工作相关的伤亡事件，但是评估工作环境的安全隐患是很重要的。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-010","input":"告诉我们您的安全顾虑 — 咨询会帮您找出解决方案联系当地现场咨询办公室，预约一次咨询访问。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-010","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-011","input":"您的企业唯一义务是，在合理的时间内，纠正不安全，不健康的工作条件。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-011","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-013","input":"雇主，工人代表，以及顾问，三者协同详谈该企业，并找出现有的和潜在的安全隐患。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-013","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-015","input":"在结束会议上，顾问会和您，以及工人代表，一起详细查看所找出的安全隐患。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-015","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-017","input":"顾问离开后，您会收到一份详细的纸质版咨询报告总结，确认所需纠正之处。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-017","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-018","input":"若一个情况被定义为“严重”的安全隐患，顾问会帮您开展一个计划，在合理的时间框架内，纠正安全隐患，并同时保护您的工人。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-018","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-019","input":"顾问是谁? 州机关和大学都咨询安全与工业卫生专家。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-019","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-021","input":"顾问会帮您找出您企业中的安全与健康需求，并预约一个对您方便的日期。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-021","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-small-business-consultation-simplified-v1/sentence-022","input":"求职者更看好一个拥有强大安全记录的潜在雇主。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4230.pdf","source_case_id":"sentence-022","split":"document"},"source_id":"osha-small-business-consultation-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-001","input":"工人在作业区的死亡或受伤，很多是由车辆或其他移动装置的撞击所导致。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-001","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-002","input":"作业区的交通需要通过标识、锥筒、筒和分隔物来划分、控制。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-002","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-004","input":"建设或拆迁工地内的交通控制方案由施工项目经理确定。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-004","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-005","input":"司机按照交通控制设备、信号灯和标示牌所指示的路线，在远离作业区的地方行驶。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-005","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-007","input":"作业区防护：各种混凝土、水马、沙袋、可折叠标识物、防撞垫和卡车减震器可以用来限制司机未经授权进入施工区域。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-007","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-008","input":"信号：信号旗手应穿着具有荧光背景并由反光材料制成的高可见度的工作服，这使其在任何方向至少1000英尺（300米）的范围内都可被看见。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-008","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-009","input":"检查标签或包装以确保服装的性能等级为2级或3级。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-009","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-010","input":"应警告司机前方会有信号旗手。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-010","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-011","input":"信号旗手应使用“停止/减速”棒、带灯的信号棒，或（仅在紧急情况下）信号旗。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-011","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-012","input":"照明：信号站应有良好的照明。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-012","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-013","input":"徒步工人和设备操作员的照度应至少为5英尺烛光（约 54勒克斯）或更高。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-013","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-014","input":"在现有照明不足的情况下，应使用频闪灯或燃烧棒；使用时应控制或消除眩光。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-014","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-015","input":"培训：信号旗手必须经过培训并经认证，且使用经授权的信号装置。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-015","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"osha-work-zone-traffic-simplified-v1/sentence-016","input":"行驶：应按照制造商的建议在设备和车辆上使用安全带和翻车保护装置。","provenance":{"raw_url":"https://www.osha.gov/sites/default/files/publications/OSHA4291.pdf","source_case_id":"sentence-016","split":"document"},"source_id":"osha-work-zone-traffic-simplified-v1"}],"converter_output_used":false,"dataset":"blind-v2","generated_date":"2026-07-23","input_only":true,"name":"blind-v2-source-classification-batch-010","seed":20260719,"selection_policy":"equal-source-deterministic-sha256-v1","selection_round":1,"source_snapshots":[{"id":"osha-chainsaw-safety-simplified-v1","path":"benchmarks/accuracy/external/osha-chainsaw-safety-simplified-v1.json","sha256":"1d2c6b40bc30c0f3dca097963787716e3413035c7f722af9f8e226888fdeb382"},{"id":"osha-disaster-cleanup-simplified-v1","path":"benchmarks/accuracy/external/osha-disaster-cleanup-simplified-v1.json","sha256":"8e6d4833214006ab34b61d3cbfb65b80f9604cf3b407d0d68a030d10460526ff"},{"id":"osha-disaster-falls-simplified-v1","path":"benchmarks/accuracy/external/osha-disaster-falls-simplified-v1.json","sha256":"37dc880aa25e367b6de9aa4cc754ca0d2d10e2ecc6ed3eb1addc15a090fcdfab"},{"id":"osha-electrical-safety-simplified-v1","path":"benchmarks/accuracy/external/osha-electrical-safety-simplified-v1.json","sha256":"eec9307a20ea41ab9e9f17f726973a36dc9b6b607ecfadbb5582d703b0e93d90"},{"id":"osha-fallen-workers-family-simplified-v1","path":"benchmarks/accuracy/external/osha-fallen-workers-family-simplified-v1.json","sha256":"9fd65ae6ef13f04cff63bf61536c82735a011c355ec098f551c4429778f7e152"},{"id":"osha-small-business-consultation-simplified-v1","path":"benchmarks/accuracy/external/osha-small-business-consultation-simplified-v1.json","sha256":"cd83181968a804ea24da4e2cce59a453c8aaed60e82948c37f78985d008daf56"},{"id":"osha-work-zone-traffic-simplified-v1","path":"benchmarks/accuracy/external/osha-work-zone-traffic-simplified-v1.json","sha256":"d8d4340b447f69284b7757d6e4c15e49336c24f807d58235f7df69661aa503b1"}],"stats":{"by_source":{"osha-chainsaw-safety-simplified-v1":15,"osha-disaster-cleanup-simplified-v1":15,"osha-disaster-falls-simplified-v1":14,"osha-electrical-safety-simplified-v1":14,"osha-fallen-workers-family-simplified-v1":14,"osha-small-business-consultation-simplified-v1":14,"osha-work-zone-traffic-simplified-v1":14},"total":100},"status":"needs_codex_first_pass","version":1}
