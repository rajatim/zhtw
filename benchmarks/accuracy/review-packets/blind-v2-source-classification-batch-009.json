{"batch_number":9,"batch_size":100,"cases":[{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-001","input":"地震是由地表深处的岩石移动引起的突然、快速的地面震动，会导致火灾、海啸、山体滑坡或雪崩。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-001","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-003","input":"为任何灾难做好防备的最佳时间是在发生之前。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-003","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-004","input":"与家人和同事练习如何在地震发生时保护自己。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-004","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-005","input":"制定应急计划：制定一个有州外联系人的家庭应急通信计划。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-005","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-007","input":"制作一个备灾用品包，含有够几天用的食物和用水、一个手电筒、一个灭火器和一个口哨。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-007","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-008","input":"做好防备可避免不必要的远足，在家中解决轻微的医疗问题，减轻紧急护理中心和医院的负担。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-008","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-009","input":"切记：并非每个人都能负担得起储备应对需要的必需品。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-009","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-010","input":"如果负担得起，应进行必要的购买并慢慢积累用品。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-010","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-011","input":"保护住房：固定好家中的重物，如书柜、冰箱、热水器、电视和墙上挂的物品。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-011","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-012","input":"将重物和易碎物放在低的架子上。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-012","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-013","input":"考虑改进住房，以解决在地震中可能导致倒塌的结构问题。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-013","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-014","input":"考虑购买地震保单。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-014","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-016","input":"如在车中，应靠边停车。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-016","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-018","input":"如在床上，脸朝下，用枕头盖住头部和颈部。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-018","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-021","input":"无论身在何处，都要双手双膝着地，抓住坚固的东西。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-021","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-022","input":"如果使用带座椅的轮椅或助行器，务必锁定轮子，保持就位，直到晃动停止。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-022","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-024","input":"如果附近有坚固的桌子或书桌，爬到下面用作庇护所。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-024","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-025","input":"如果附近没有庇护所，爬到内墙旁边（远离窗户）。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-025","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-026","input":"如能不经过碎片更多的地方，可爬到更好的掩体处。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-026","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-029","input":"如果坐着且无法爬到在地，向前弯腰，用双手盖住头部和颈部。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-029","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-030","input":"地震后可能会出现严重的危险，例如，建筑物损坏、煤气和水管泄漏或电线掉落。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-030","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-031","input":"预期主震后会有余震。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-031","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-032","input":"如果感到余震，准备好爬下、盖住和扶好。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-032","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-033","input":"如在损坏的建筑物内，应到外面，迅速离开建筑物。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-033","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-035","input":"如果被困，发送短信或敲打水管或墙壁。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-035","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-038","input":"避免接触洪水，因为水里可能有化学物质、污水和碎屑。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-038","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-039","input":"检查自己是否受伤，如果受过培训，可帮助他人。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-039","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-040","input":"了解如何在救援到来之前提供帮助。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-040","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-041","input":"如因生病或受伤而需就医，联系医护人员获取说明。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-041","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-042","input":"安全后，留意当地新闻报道，通过电池供电的收音机、电视、社交媒体或手机短信警示获取紧急情况信息和说明。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-042","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-043","input":"使用短信进行交流，因为可能比电话更可靠。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-043","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-044","input":"穿好防护服，包括长袖衬衫，长裤，工作手套和坚固的厚底鞋。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-044","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-046","input":"清洁霉菌或其他碎屑时，应戴上合适的面罩。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-046","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-earthquakes-zh-hans-v1/sentence-047","input":"如患哮喘和其他肺部疾病和/或免疫抑制，则不应进入室内有可以看到或闻到漏水或霉菌生长的建筑物。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/earthquakes","source_case_id":"sentence-047","split":"article"},"source_id":"ready-gov-earthquakes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-001","input":"洪水就是大水暂时溢出到通常干燥的土地上，是美国最常见的自然灾害。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-001","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-002","input":"不撤离洪水淹没的地区或进入洪水能导致受伤或死亡。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-002","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-004","input":"缓慢或快速发展。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-004","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-005","input":"山洪暴发可能毫无征兆。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-005","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-006","input":"造成停电、中断交通、损坏建筑物并造成山体滑坡。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-006","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-007","input":"立即寻找安全的庇护所。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-007","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-008","input":"切勿步行、游泳或驾车穿越洪水。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-008","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-009","input":"离开，别淹死了！","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-009","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-010","input":"切记：只需 6 英寸的流水就能击倒人，而 1 英尺流水就能将车辆冲走。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-010","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-012","input":"根据洪水类型：获知撤离时，务必撤离。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-012","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-013","input":"去到更高的地面或更高的楼层。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-013","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-014","input":"访问 FEMA 洪水地图服务中心，了解所在地区的洪水风险类型。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-014","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-015","input":"注册社区警告系统。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-015","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-017","input":"购买或更新洪水保单。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-017","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-019","input":"保单生效通常需要长达 30 天的时间，因此购买时间应在灾害发生之前。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-019","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-020","input":"从国家洪水保险计划 (NFIP) 购买洪水保险。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-020","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-021","input":"制定一个计划供家庭（包括宠物）使用，以便您和您的家人知道该做什么、去哪里及您需要什么来保护自己免受洪水侵害。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-021","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-022","input":"学习和演习疏散路线、庇护所计划和山洪暴发响应。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-022","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-023","input":"备好几天的用品，包括不易腐烂的食物、清洁用品和用水，以防必须立即离开或所在地区服务中断。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-023","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-025","input":"创建密码保护的数字副本。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-025","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-028","input":"考虑用电池的液下泵。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-028","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-029","input":"获知要撤离时，立即撤离。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-029","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-031","input":"当地的响应者用来将交通安全地引出洪水区。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-031","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-040","input":"不要爬上封闭的阁楼，以免被不断上升的洪水困住。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-040","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-042","input":"只有在当局说安全时才能回家。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-042","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-043","input":"除非有紧急情况，否则要避免开车。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-043","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-045","input":"如患哮喘和其他肺部疾病和/或免疫抑制，则不应进入室内有可以看到或闻到漏水或霉菌生长的建筑物。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-045","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-046","input":"儿童不应参加灾后清理工作。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-046","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-047","input":"请注意，蛇和其他动物可能在您的房屋中。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-047","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-049","input":"如果电器设备潮湿或您站在水中，请勿触摸。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-049","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-051","input":"避免踏入洪水中，水可能已被污染，并含有危险的碎屑。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-051","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-052","input":"地下或掉落的电线也可能给水导电。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-052","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-floods-zh-hans-v1/sentence-053","input":"仅在室外且远离窗户的地方使用发电机或其他汽油动力机械。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/floods","source_case_id":"sentence-053","split":"article"},"source_id":"ready-gov-floods-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-001","input":"飓风十分危险，可能因风暴潮、强风、离岸流和洪水造成重大破坏。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-001","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-004","input":"在西北太平洋部分地区，飓风被称为台风。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-004","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-005","input":"东太平洋飓风季：5月15日至11月30日。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-005","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-010","input":"制定应急计划确保家庭每个成员了解并掌握您的飓风应对计划。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-010","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-011","input":"如果您或家庭其他成员是残障人士，请评估紧急情况下是否需要额外帮助。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-011","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-013","input":"了解您的疏散区域如果您居住在疏散区域，可能需要因飓风迅速撤离。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-013","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-014","input":"熟悉疏散路线，与家人及宠物一起演练，并确定避难地点。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-014","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-016","input":"他们将根据社区面临的威胁提供最新建议，发布安全措施。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-016","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-017","input":"识别预警与警报请确保拥有多种接收警报的途径。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-017","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-018","input":"请下载 FEMA 应用程序，您可以最多就全国五个区域，接收来自国家气象局的实时天气和紧急警报。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-018","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-020","input":"审阅重要文件确保您的保险单和个人文件（如身份证件）是最新版。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-020","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-021","input":"制作副本并将其保存在安全、受密码保护的数字空间内。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-021","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-022","input":"加固房屋清理排水口和排水沟，将户外家具搬入室内，考虑安装防飓风百叶窗。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-022","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-023","input":"做好技术准备一旦预报飓风来袭，请保持手机电量充足，购买备用充电设备以供电子设备使用。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-023","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-025","input":"将药品、消毒用品和宠物用品放入应急包或汽车后备箱中。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-025","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-030","input":"应对天气确定如何最好地保护自己免受强风和洪水的侵害。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-030","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-032","input":"如果您被洪水困住，请前往建筑物的最高层。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-032","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-034","input":"您可能会被上涨的洪水困住。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-034","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-035","input":"不要在洪水中行走、游泳或开车。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-035","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-036","input":"仅六英寸的快速流动的水就可以将您击倒，一英尺的流动水可以冲走您的车辆。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-036","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-037","input":"请关注当地官方发布的信息和特别指示。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-037","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-038","input":"清理时请务必小心谨慎。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-038","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-041","input":"儿童不应参与灾后清理工作。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-041","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-042","input":"请穿戴防护服，与他人协同作业。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-042","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-043","input":"在潮湿场合或如果您站立在水中，切勿接触电气设备。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-043","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-045","input":"请勿涉入洪水，因为其中可能含有导致疾病的危险病原体。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-045","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-046","input":"洪水中还可能含有碎片、化学品、垃圾和野生动物。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-046","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-047","input":"地下或倒塌的电线可能使水带电。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-047","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-048","input":"请将电话留作紧急情况使用。","provenance":{"raw_url":"https://www.ready.gov/zh-hans/hurricanes","source_case_id":"sentence-048","split":"article"},"source_id":"ready-gov-hurricanes-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"ready-gov-hurricanes-zh-hans-v1/sentence-049","i