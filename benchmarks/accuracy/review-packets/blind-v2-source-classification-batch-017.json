{"batch_number":17,"batch_size":100,"cases":[{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-001","input":"在当今的威胁环境中，所有关键基础设施员工都应该保持警惕并承担起个人安全责任，不仅在日常工作中应当如此，生活中也不能懈怠。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-001","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-002","input":"关键基础设施员工从事大量的服务工作，负责操作、运行和维护现代美国生活所必需的关键系统和资产。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-002","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-003","input":"注意与您工作相关的任何风险或威胁，并遵守所有安全程序将有助于保护您、您身边的人以及您所服务的基础设施。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-003","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-004","input":"个人安全可分为三个主要部分：人身安全、态势感知和网络安全。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-004","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-006","input":"提供面对面的服务或护理。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-006","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-007","input":"处理危险材料或涉及国家安全的敏感信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-007","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-008","input":"负责保护当地或国家关键基础设施。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-008","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-010","input":"是否有可靠证据表明您面临风险？","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-010","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-011","input":"您过去是否遭受过攻击或威胁？","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-011","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-012","input":"您个人具有的视觉标识符。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-012","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-016","input":"在评估您的个人安全时，关键在于采取一种平衡的方法，并记得把您的家庭和工作生活考虑在内—在您采取个人安全实践和培养此类习惯时保持警惕，并不断评估您周围的环境。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-016","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-017","input":"您应根据感知到的威胁采取适当的措施。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-017","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-018","input":"安全措施过多可能会给您带来不必要的压力和不便；然而，安全措施不充分可能会将您置于危险之中。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-018","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-020","input":"攻击者将个人作为目标时可谓花样百出。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-020","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-021","input":"攻击者发起攻击可能是为了制造尴尬、造成不便、干扰他人，也可能是想要对他人造成人身伤害、损害其健康或威胁其生命。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-021","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-022","input":"您可以考虑采取许多简单的措施，以保护您和您的家。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-022","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-023","input":"首先，您需要在住宅或房产周围安装安全系统或对其加以改进。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-023","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-024","input":"您可用锁、钥匙、警报器和灯来保护门窗，并评估是否需要安装闭路电视 (CCTV) 系统。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-024","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-025","input":"您可考虑在入口处和窗户上采用先进的门锁系统，并安装监控（多视角）视频监视系统。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-025","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-027","input":"您可考虑移除任何可造成破坏的东西，如松动的砖块、大石头和花园装饰品。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-027","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-028","input":"不会阻挡家中人员向外看的视线。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-028","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-029","input":"您可使用适当的锁具（包括电子锁和密码锁）保护外部门窗。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-029","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-030","input":"最好多准备一套钥匙或入室密码，以便能在紧急情况下使用。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-030","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-031","input":"如果密码泄露或钥匙丢失，您应考虑更换整个门锁系统。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-031","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-032","input":"您可出资在外部安装照明并加以维护，以照亮外门、停车场和房屋周围的人行道。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-032","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-033","input":"考虑安装可以看到门窗的摄像头。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-033","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-034","input":"您应将这些照明灯和摄像头布置在合适的位置，以消除个人可能躲避侦查的盲点。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-034","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-035","input":"如果您有车辆，但无法将其停放在车库或上锁的区域，可以尝试将其停放在公共视线可见的范围内。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-035","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-036","input":"请将车停在光线充足的地方、 CCTV 摄像头能看到的地方或有人看管的停车场。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-036","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-039","input":"除了车辆定位服务，还可启用包含声音和视觉通知的系统，以协助警方加快应对的脚步。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-039","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-041","input":"抗议活动看似令人生畏，但造成人身威胁的可能性不大。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-041","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-042","input":"即使局势变得不稳定，您也要保持冷静。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-042","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-043","input":"请待在室内，关好并锁好门窗，拉上窗帘/百叶窗。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-043","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-044","input":"如果您感觉不安全或局势加剧，请致电当地执法部门。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-044","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-047","input":"CISA 发布的《公众示威期间保护基础设施情况说明书》为可能在公众示威期间成为非法行为目标的企业提供了安全建议。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-047","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-048","input":"态势感知是指了解周围发生的一切，考虑到所有情况并调整自己的行为，以降低自己、家人或同事受伤的风险。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-048","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-050","input":"考虑安装猫眼或门上摄像头，以帮助您识别门外人的身份。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-050","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-051","input":"在开门之前，请不明来历的访客表明身份。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-051","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-052","input":"进入住宅后，始终与其维持近距离，最好让他们待在您面前或其他您能监测的位置。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-052","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-054","input":"始终妥善处理或销毁可能含有敏感或个人身份信息 (PII) 的机密材料。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-054","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-055","input":"PII 包括可用于识别您身份的任何个人信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-055","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-056","input":"在公共场所活动、行走或慢跑时，请时刻关注个人安全。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-056","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-058","input":"您可考虑采取一些简单的措施，如提前规划好安全路线，去固定地点时变更路线，避开潜在的危险场所，如安静或光线不足的小巷、荒凉的停车场和偏僻的停车场。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-058","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-059","input":"如果您在公共场所/环境中感到担忧或感觉不安全，请靠近人群。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-059","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-060","input":"在接受拼车和进入车辆之前，请检查司机和车辆的详细信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-060","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-063","input":"避免展示任何珠宝或贵重物品。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-063","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-064","input":"考虑该区域的照明、位置以及与当地其他企业的距离。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-064","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-065","input":"行走时应面对来往车辆，以避开从后方驶来的车辆。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-065","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-066","input":"保持双手空闲，时刻注意周围环境。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-066","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-068","input":"行走时保持警惕，请勿逗留。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-068","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-070","input":"请考虑携带胡椒喷雾、声音警报器或其他个人保护装置，以干扰攻击者、通知旁观者并为自己创造逃跑的机会。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-070","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-071","input":"请在条件允许的情况下根据联邦和当地的法律法规，携带并使用个人保护装置。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-071","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-072","input":"无论您何时身处公共场合，都要谨慎行事，并采取预防措施隐藏任何工作凭证或个人信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-072","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-073","input":"在公共场所佩戴工牌或输入密码时要小心谨慎。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-073","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-074","input":"识别并报告可疑活动，例如有人在您家、您的工作场所或车辆周围无故闲逛，或有人试图以隐蔽的方式为您拍照。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-074","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-076","input":"系统和设备损坏或被篡改。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-076","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-077","input":"可疑或无人看管的物品，包括可能装有危险物质的包、箱、隐藏式容器。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-077","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-078","input":"对建筑平面图、出入口位置、电梯、灭火器、供水以及供暖、通风和空调 (HVAC) 系统发出的可疑询问。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-078","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-079","input":"易燃或可燃材料数量或位置异常，包括助燃剂、油漆、脱脂剂、酒精清洁剂、气雾剂和丙烷气罐。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-079","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-081","input":"发现自己身处冲突之中可能会让人感到紧张。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-081","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-082","input":"应重点关注可观察到的、可表明存在潜在暴力的行为。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-082","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-083","input":"在这种情况下，关键在于保持冷静并评估局势，以确定自己能否安全地参与其中。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-083","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-084","input":"考虑自己的能力极限，在安全的情况下尽快寻求安保人员或执法人员的协助。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-084","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-085","input":"如果您接受过培训并熟练掌握相关技能，可以考虑采取目的明确的行动（包括有效的倾听和沟通），安全地缓和激烈的局势。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-085","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-087","input":"及时更新软件，让攻击者无法利用敏感信息或漏洞。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-087","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-088","input":"许多操作系统都提供自动更新功能。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-088","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-089","input":"如果可以选择自动更新，请在设备的应用程序安全设置中打开自动更新。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-089","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-090","input":"离开家或工作场所之前，请环顾四周，注意任何可能在此潜伏或游荡的可疑车辆。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-090","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-091","input":"检查车辆周围是否有任何不应出现在车辆上或附近的东西。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-091","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-093","input":"如果可能，避免在旅行行程中出现重复的安排，这样潜在的恶意行为者就无法预测您的行踪。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-093","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-094","input":"尽可能改变路线和出发时间。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-094","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-096","input":"仅打开通风所需的窗户。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-096","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-099","input":"如果您认为自己被跟踪，请尽量保持冷静并保持车辆正常行驶。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_Z