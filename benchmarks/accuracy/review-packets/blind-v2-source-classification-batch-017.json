rce_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-105","input":"听从执法人员的指示。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-105","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-107","input":"请勿从未知或无法验证来源处下载应用程序。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-107","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-108","input":"在每个提供多因素身份验证 (MFA) 的账户或应用程序上启用该功能。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-108","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-109","input":"启用 MFA 有助于保护您的个人信息，如电子邮件、社交媒体、财务和其他重要信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-109","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-110","input":"在网上发布信息时，请务必注意发布的内容和方式。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-110","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-111","input":"如果您发布的信息过多而又没有进行适当的隐私设置，您可能会将自己的人身安全置于危险之中。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-111","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-112","input":"他人可以利用这类信息来了解您的人际关系、观点、感兴趣的领域和其他主题，以便在将来加以利用。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-112","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-113","input":"数据经纪商也会收集这类个人信息，并将其卖给其他公司。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-113","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-114","input":"请勿在社交媒体上接受现实生活中不认识的人的好友请求。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-114","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-116","input":"限制应用程序权限。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-116","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-117","input":"为您的姓名设置 Google 快讯。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-117","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-118","input":"考虑花点时间退出主要数据经纪商和人员搜索网站的数据共享，或者订阅一项服务来帮您退出。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-118","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-119","input":"社交网络平台允许用户发布基于位置的信息，支持 GPS 的手机和移动设备发布此类信息尤其方便。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-119","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-120","input":"发布这类信息并不安全，任何人都能看到该信息，包括可能想伤害您的人。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-120","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-122","input":"记录下所发生的一切并截屏与调查人员分享。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-122","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-123","input":"确定哪些信息遭到利用、威胁的严重程度和漏洞所在之处。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-123","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-124","input":"与网站管理员合作，删除网站或应用程序中的信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-124","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-125","input":"在隐私设置中选择私密度最高的选项。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-125","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-126","input":"注意身份盗窃的迹象，监测金融账户，设置欺诈警报，更改所有在线账户的登录和密码信息。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-126","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_flags":[],"risk":null,"script":null},"id":"cisa-personal-security-zh-hans-v1/sentence-129","input":"犯罪分子经常使用网络钓鱼策略让您打开有害链接、电子邮件或附件，这些链接、电子邮件或附件可能会要求您提供个人信息或感染您的设备。","provenance":{"raw_url":"https://www.cisa.gov/sites/default/files/2025-03/personal-security-considerations-action-guide-critical-infrastructure-workers_06-07-2024_508_ZHS.pdf","source_case_id":"sentence-129","split":"guide"},"source_id":"cisa-personal-security-zh-hans-v1"},{"classification":{"confidence":null,"domain":null,"eligible":null,"notes":"","quality_fla