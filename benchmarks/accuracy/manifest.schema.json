{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rajatim/zhtw/benchmarks/accuracy/manifest.schema.json",
  "title": "zhtw accuracy benchmark dataset manifest",
  "type": "object",
  "required": [
    "version",
    "id",
    "track",
    "source_urls",
    "upstream_revision",
    "retrieved_at",
    "license",
    "license_url",
    "output_license",
    "attribution",
    "modification_notice",
    "notice_id",
    "raw_sha256",
    "normalized_path",
    "normalized_sha256",
    "importer",
    "known_biases",
    "allowed_uses",
    "tuning_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "track": {
      "type": "string",
      "enum": ["external_context", "external_terminology", "external_regional", "blind"]
    },
    "source_urls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "format": "uri" }
    },
    "upstream_revision": { "type": "string", "minLength": 1 },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "license": { "type": "string", "minLength": 1 },
    "license_url": { "type": "string", "format": "uri" },
    "output_license": { "type": "string", "minLength": 1 },
    "attribution": { "type": "string", "minLength": 1 },
    "modification_notice": { "type": "string", "minLength": 1 },
    "notice_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "raw_sha256": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "normalized_path": { "type": "string", "minLength": 1 },
    "normalized_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "importer": { "type": "string", "pattern": "^scripts/[A-Za-z0-9_.-]+\\.py$" },
    "known_biases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_uses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["evaluation", "public_reporting"] }
    },
    "tuning_policy": {
      "type": "string",
      "enum": ["public_track_only", "sealed_no_tuning"]
    }
  }
}
